# FlightView Configuration
# Copy this file to .env and fill in your values.

# Home location coordinates (required)
HOME_LAT=47.6062
HOME_LON=-122.3321

# Maximum altitude in feet to display aircraft (default: 3000)
ALTITUDE_LIMIT_FT=3000

# Maximum radius in feet from home location (default: 1500)
RADIUS_LIMIT_FT=1500

# Polling interval in seconds for OpenSky API (default: 5)
POLL_INTERVAL_SEC=5

# ADS-B Exchange API key (optional, for route enrichment)
ADSBX_API_KEY=

# Enable mock data mode for development (default: False)
MOCK_MODE=False
