# FlightView Configuration
# Copy this file to .env and fill in your values.

# Home location coordinates (required)
HOME_LAT=47.6062
HOME_LON=-122.3321

# Near zone — triggers single-plane detail view
ALTITUDE_LIMIT_FT=3000
RADIUS_LIMIT_FT=1500

# Far zone — shown on radar scope and card strips
RADAR_ALTITUDE_FT=15000
RADAR_RADIUS_FT=15000

# Polling interval in seconds for OpenSky API (default: 15)
POLL_INTERVAL_SEC=15

# FlightAware AeroAPI key (optional, for route enrichment on detail view)
# Sign up at https://www.flightaware.com/aeroapi/ — free tier gives $5/month
ADSBX_API_KEY=

# OpenSky Network OAuth2 credentials (optional, reduces rate limiting)
# Create an API client at https://opensky-network.org after signing up
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Enable mock data mode for development (default: False)
MOCK_MODE=False

# Data source: "rtlsdr" (default) | "opensky" | "mock"
# When set, this overrides MOCK_MODE. If omitted, MOCK_MODE=true → mock, else rtlsdr.
DATA_SOURCE=rtlsdr

# dump1090 / readsb base URL (for RTL-SDR data source)
# Default: http://localhost:8080 — standard dump1090/readsb JSON endpoint
DUMP1090_URL=http://localhost:8080
